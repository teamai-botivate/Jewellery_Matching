# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Kaggle API token (for setup_dataset.py)
KAGGLE_API_TOKEN=your_kaggle_token_here

# Qdrant — set QDRANT_URL for Qdrant Cloud, or leave blank for local server
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=https://your-cluster.us-west-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# OpenCLIP model
CLIP_MODEL=ViT-B-32
CLIP_PRETRAINED=openai

# Set to false on Render (no rembg on server — index locally first)
REMBG_PREPROCESSING=false
